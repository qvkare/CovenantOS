[Unit]
Description=CovenantOS Docker stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/srv/covenantos
EnvironmentFile=/srv/covenantos/.env
ExecStart=/usr/bin/docker compose -f infra/docker-compose.prod.yml up -d --remove-orphans
ExecStop=/usr/bin/docker compose -f infra/docker-compose.prod.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
