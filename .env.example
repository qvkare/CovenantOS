# Odra livenet deploy (run from contracts/)
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network/rpc
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
ODRA_CASPER_LIVENET_EVENTS_URL=https://events.testnet.casper.network/events
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=../keys/deployer_secret_key.pem

# Anthropic (Phase 4)
ANTHROPIC_API_KEY=

