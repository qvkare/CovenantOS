# Backend
PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgres://covenantos:covenantos@localhost:5432/covenantos

# Casper Testnet — use .env for real values (never commit secrets)
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CASPER_SECRET_KEY_HEX=
CASPER_PUBLIC_KEY=
CASPER_SECRET_KEY_PATH=./keys/deployer_secret_key.pem
CSPR_CLOUD_URL=https://api.testnet.cspr.cloud
# CSPR_CLOUD_AUTH_TOKEN=   # enables live contract-event indexer via WebSocket
# CSPR_CLOUD_STREAMING_URL=wss://streaming.testnet.cspr.cloud
# INDEXER_ENABLED=true       # set false to disable chain indexer startup

# Odra livenet deploy (run from contracts/)
# Node address must NOT include /rpc — Odra appends it internally.
# Events: public testnet peer SSE firehose (port 9999) or CSPR.cloud with CSPR_CLOUD_AUTH_TOKEN.
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
ODRA_CASPER_LIVENET_EVENTS_URL=http://65.21.14.26:9999/events
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=../keys/deployer_secret_key.pem

# Anthropic Document Agent
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# x402 data provider (native CSPR micropayments on testnet)
PROVIDER_URL=http://localhost:3002
X402_PAYEE_ACCOUNT_HASH=
X402_PAYMENT_AMOUNT_MOTES=1000000
X402_BUDGET_CAP_MOTES=10000000000

# Provider service
# PORT=3002

# Frontend (web/)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_MSW=true
NEXT_PUBLIC_CSPRCLICK_APP_ID=csprclick-template

# Production (covenantos.xyz — set in infra/docker-compose.prod.yml build args)
# NEXT_PUBLIC_API_URL=https://api.covenantos.xyz
# NEXT_PUBLIC_MSW=false

# Demo / security
DEMO_MODE=true
# DEMO_RESET_TOKEN=   # optional: require X-Demo-Reset-Token header on POST /demo/reset
